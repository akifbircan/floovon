{
  "name": "floovon-backend-professional",
  "version": "2.0.0",
  "description": "Floovon Professional Backend API - Çiçek ve Organizasyon Yönetim Sistemi",
  "main": "simple-server.js",
  "scripts": {
    "start": "node simple-server.js",
    "dev": "nodemon simple-server.js",
    "cards": "node cards-server.js",
    "customers": "node customers-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "smoke-test": "node scripts/smoke-test.js",
    "migrate": "node src/utils/migrate.js",
    "migrations": "node run-migrations.js",
    "seed": "node src/utils/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docs": "swagger-jsdoc -d swaggerDef.js src/routes/*.js -o docs/",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t floovon-backend .",
    "docker:run": "docker run -p 3000:3000 floovon-backend"
  },
  "keywords": [
    "floovon",
    "backend",
    "api",
    "flower",
    "organization",
    "management",
    "professional",
    "express",
    "sqlite",
    "jwt"
  ],
  "author": "Floovon Development Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "6.0.0",
    "bcryptjs": "2.4.3",
    "cheerio": "1.1.2",
    "chokidar": "4.0.3",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "ejs": "3.1.10",
    "express": "4.21.2",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "7.5.1",
    "express-slow-down": "2.1.0",
    "express-validator": "7.2.1",
    "helmet": "7.2.0",
    "hpp": "0.2.3",
    "joi": "17.13.3",
    "jsonwebtoken": "9.0.2",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "multer": "1.4.5-lts.2",
    "nodemailer": "6.10.1",
    "puppeteer": "23.6.1",
    "qrcode-terminal": "0.12.0",
    "sharp": "0.33.5",
    "sqlite3": "5.1.7",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "uuid": "9.0.1",
    "whatsapp-web.js": "1.34.6",
    "winston": "3.18.3",
    "xss": "1.0.15",
    "yamljs": "0.3.0"
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "jest": "29.7.0",
    "nodemon": "3.1.10",
    "supertest": "6.3.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/floovon/backend-professional.git"
  },
  "bugs": {
    "url": "https://github.com/floovon/backend-professional/issues"
  },
  "homepage": "https://github.com/floovon/backend-professional#readme"
}
