# API Base URL
# Geliştirme (npm run dev, port 5174): BOŞ BIRAKIN - istekler /api üzerinden Vite proxy ile 3001'e gider
# Production: /api (relative path, Nginx proxy üzerinden)
VITE_API_BASE_URL=

# Environment
# Development: true
# Production: false
VITE_DEV=false

# Backend Port (Development için)
# Backend: 3001, React dev server: 5174
VITE_BACKEND_PORT=3001

# Şifre sıfırlama mailindeki linkin gideceği adres (opsiyonel)
# Uygulama localhost:3001'den sunulsa bile link localhost:5174'e gitsin istiyorsanız:
# VITE_APP_PUBLIC_ORIGIN=http://localhost:5174
# Production'da genelde boş bırakılır (panel ile aynı domain kullanılır)
VITE_APP_PUBLIC_ORIGIN=